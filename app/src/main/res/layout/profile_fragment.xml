<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:clipToPadding="false"
    android:paddingBottom="16dp"
    tools:context=".fragments.ProfileFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="16dp"/>

        <!-- 1. Profile Summary Card -->
        <androidx.cardview.widget.CardView
            style="@style/Widget.Material3.CardView.Elevated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center_horizontal">

                <!-- Placeholder Avatar -->
                <ImageView
                    android:id="@+id/img_profile_avatar"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginBottom="12dp"
                    android:scaleType="fitXY"
                    android:background="@drawable/circle_background"
                    app:tint="@android:color/white"
                    android:src="@drawable/ic_profile"
                    tools:ignore="ContentDescription" />
                <!-- NOTE: You will need to define a drawable resource named 'ic_user' -->

                <TextView
                    android:id="@+id/text_user_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/guest_user"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/text_user_weight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/current_weight_65_0_kg"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary_gray"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 2. Personal Information Card (Static Info Display) -->
        <androidx.cardview.widget.CardView
            style="@style/Widget.Material3.CardView.Elevated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Account Details"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/darker_blue"
                    android:layout_marginBottom="12dp"/>

                <!-- Detail Row Example (Age) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Age"
                        android:textColor="@color/black"
                        android:textSize="16sp"/>
                    <TextView
                        android:id="@+id/detail_age"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="22 years"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark_primary"
                        android:textSize="16sp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB"/>

                <!-- Detail Row Example (Height) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Height"
                        android:textColor="@color/black"
                        android:textSize="16sp"/>
                    <TextView
                        android:id="@+id/detail_height"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="170 cm"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark_primary"
                        android:textSize="16sp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 3. Settings/Preferences Card -->
        <androidx.cardview.widget.CardView
            style="@style/Widget.Material3.CardView.Elevated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="App Preferences"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_log_purple"
                    android:layout_marginBottom="12dp"/>

                <!-- Setting 1: Notifications -->
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_notifications"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:paddingVertical="8dp"
                    android:text="Daily Reminder Notifications"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    tools:ignore="TouchTargetSizeCheck" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB"/>

                <!-- Setting 2: Unit System -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Unit System"
                        android:textColor="@color/black"
                        android:textSize="16sp"/>
                    <!-- Use a Spinner or RadioGroup in a real app, using a Button placeholder here -->
                    <Button
                        android:id="@+id/btn_unit_system"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Metric (kg/cm)"
                        android:textSize="14sp"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:textColor="@color/dark_text_primary"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>


        <!-- 4. Action Button -->
        <Button
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Log Out"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="@color/deep_orange"
            android:textColor="@android:color/white"
            app:cornerRadius="16dp"
            android:layout_marginTop="16dp"
            style="@style/Widget.Material3.Button.ElevatedButton"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="100dp"/>

    </LinearLayout>
</ScrollView>
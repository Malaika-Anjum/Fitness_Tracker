<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:clipToPadding="false"
    android:paddingBottom="16dp"
    tools:context=".HistoryActivity">

    <!-- ConstraintLayout as the single container for all elements -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="24dp">

        <!-- 1. Header -->
        <TextView
            android:id="@+id/tv_history_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Health Trends &amp; History"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1F2937"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- 2. Period Selector (Week/Month/Year) -->
        <!-- NOTE: This LinearLayout will require custom XML Drawables/ColorStateLists to manage button states -->
        <LinearLayout
            android:id="@+id/ll_period_selector"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:background="@drawable/selector_background"
            android:padding="4dp"
            app:layout_constraintTop_toBottomOf="@id/tv_history_header"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:id="@+id/btn_select_week"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Week"
                android:textColor="#1F2937"
                android:background="@drawable/selector_button_state"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                style="@style/Widget.Material3.Button.TextButton"/>

            <Button
                android:id="@+id/btn_select_month"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Month"
                android:textColor="#1F2937"
                android:background="@drawable/selector_button_state"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                style="@style/Widget.Material3.Button.TextButton"/>

            <Button
                android:id="@+id/btn_select_year"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Year"
                android:textColor="#1F2937"
                android:background="@drawable/selector_button_state"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                style="@style/Widget.Material3.Button.TextButton"/>
        </LinearLayout>

        <!-- 3. Steps Trends Chart Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cv_steps_chart"
            android:layout_width="0dp"
            android:layout_height="300dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/ll_period_selector"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@android:color/white">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Steps Trend Over Time"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1F2937"
                    android:layout_marginBottom="12dp"/>

                <!-- Placeholder for the charting library (e.g., MPAndroidChart LineChart) -->
                <View
                    android:id="@+id/steps_chart_view"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    tools:background="#E0F2F1" />

                <TextView
                    android:id="@+id/chart_summary_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Average daily steps this week: 8,200"
                    android:textSize="14sp"
                    android:textColor="#6B7280"
                    android:gravity="center"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 4. Daily Summary List Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cv_daily_summary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/cv_steps_chart"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            <!-- Constraint to bottom is critical for ScrollView calculation -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="16dp"
                android:background="@android:color/white">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daily Breakdown"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1F2937"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="8dp"/>

                <!-- RecyclerView for a scrollable list of past days -->
                <!-- The nestedScrollingEnabled="false" attribute ensures the parent ScrollView handles the scrolling. -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/daily_summary_recycler_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:itemCount="5"
                    tools:listitem="@layout/item_daily_summary"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
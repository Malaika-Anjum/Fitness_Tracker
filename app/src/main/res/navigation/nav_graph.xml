<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.miki.fitnesstracker.fragments.HomeFragment"
        android:label="Home" >
        <action
            android:id="@+id/action_homeFragment_to_logFragment"
            app:destination="@id/logFragment" />
        <action
            android:id="@+id/action_homeFragment_to_profileFragment"
            app:destination="@id/profileFragment" />
        <action
            android:id="@+id/action_homeFragment_to_goalsFragment"
            app:destination="@id/goalsFragment" />
        <action
            android:id="@+id/action_homeFragment_to_historyFragment"
            app:destination="@id/historyFragment" />
    </fragment>

    <fragment
        android:id="@+id/goalsFragment"
        android:name="com.miki.fitnesstracker.fragments.GoalsFragment"
        android:label="Goals" >
        <action
            android:id="@+id/action_goalsFragment_to_historyFragment"
            app:destination="@id/historyFragment" />
        <action
            android:id="@+id/action_goalsFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
        <action
            android:id="@+id/action_goalsFragment_to_logFragment"
            app:destination="@id/logFragment" />
        <action
            android:id="@+id/action_goalsFragment_to_profileFragment"
            app:destination="@id/profileFragment" />
    </fragment>

    <fragment
        android:id="@+id/logFragment"
        android:name="com.miki.fitnesstracker.fragments.LogFragment"
        android:label="Log" >
        <action
            android:id="@+id/action_logFragment_to_profileFragment"
            app:destination="@id/profileFragment" />
        <action
            android:id="@+id/action_logFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
        <action
            android:id="@+id/action_logFragment_to_historyFragment"
            app:destination="@id/historyFragment" />
        <action
            android:id="@+id/action_logFragment_to_goalsFragment"
            app:destination="@id/goalsFragment" />
    </fragment>

    <fragment
        android:id="@+id/historyFragment"
        android:name="com.miki.fitnesstracker.fragments.HistoryFragment"
        android:label="History" >
        <action
            android:id="@+id/action_historyFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
        <action
            android:id="@+id/action_historyFragment_to_logFragment"
            app:destination="@id/logFragment" />
        <action
            android:id="@+id/action_historyFragment_to_profileFragment"
            app:destination="@id/profileFragment" />
        <action
            android:id="@+id/action_historyFragment_to_goalsFragment"
            app:destination="@id/goalsFragment" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.miki.fitnesstracker.fragments.ProfileFragment"
        android:label="Profile" >
        <action
            android:id="@+id/action_profileFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
        <action
            android:id="@+id/action_profileFragment_to_logFragment"
            app:destination="@id/logFragment" />
        <action
            android:id="@+id/action_profileFragment_to_historyFragment"
            app:destination="@id/historyFragment" />
        <action
            android:id="@+id/action_profileFragment_to_goalsFragment"
            app:destination="@id/goalsFragment" />
    </fragment>
</navigation>
